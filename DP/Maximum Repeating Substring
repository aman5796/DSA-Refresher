class Solution:
    def maxRepeating(self, sequence: str, word: str) -> int:
        i = j = k = 0
        ans = 0
        word_len = len(word)
        while i < len(sequence):
            if sequence[i] == word[j]:
                j = j + 1
            else:
                i = i - (k*word_len or j)
                j = k = 0
            if j == word_len:
                k = k + 1
                j = 0
            i = i + 1
            ans = max(ans, k)
        return ans